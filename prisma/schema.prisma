// ============================================================
// Smart Task Prioritizer — Prisma Schema
// Database: Supabase PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// Enums
// ============================================================

enum TaskCategory {
  WORK
  STUDY
  PERSONAL
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum ScheduleBlockType {
  DEEP_WORK
  MEETING
  BREAK
  PERSONAL
}

enum NotificationType {
  REMINDER
  PROCRASTINATION_NUDGE
  BURNOUT_WARNING
  DAILY_SUMMARY
  ACHIEVEMENT
  SCHEDULE_GENERATED
}

// ============================================================
// Task 15 — User Model
// ============================================================

model User {
  id                 String   @id @default(cuid())
  clerkId            String   @unique
  email              String   @unique
  name               String?
  timezone           String   @default("UTC")
  preferredWorkStart String?  // e.g. "09:00"
  preferredWorkEnd   String?  // e.g. "17:00"
  breakDuration      Int      @default(15) // minutes
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  tasks          Task[]
  scheduleBlocks ScheduleBlock[]
  habitLogs      HabitLog[]
  notifications  Notification[]

  @@map("users")
}

// ============================================================
// Task 16 — Task Model
// ============================================================

model Task {
  id               String       @id @default(cuid())
  userId           String
  title            String
  description      String?
  category         TaskCategory @default(PERSONAL)
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(TODO)
  deadline         DateTime?
  estimatedDuration Int?        // minutes
  actualDuration   Int?         // minutes
  energyLevel      EnergyLevel  @default(MEDIUM)
  priorityScore    Float?       // 0-100, calculated by AI
  rescheduledCount Int          @default(0)
  createdAt        DateTime     @default(now())
  completedAt      DateTime?
  updatedAt        DateTime     @updatedAt

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduleBlocks ScheduleBlock[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, deadline])
  @@index([userId, priorityScore])
  @@map("tasks")
}

// ============================================================
// Task 17 — ScheduleBlock Model
// ============================================================

model ScheduleBlock {
  id        String            @id @default(cuid())
  userId    String
  taskId    String?
  date      DateTime          @db.Date
  startTime String            // "09:00" (HH:mm format)
  endTime   String            // "10:30" (HH:mm format)
  type      ScheduleBlockType @default(DEEP_WORK)
  createdAt DateTime          @default(now())

  // Relations
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@map("schedule_blocks")
}

// ============================================================
// Task 18 — HabitLog Model
// ============================================================

model HabitLog {
  id                  String   @id @default(cuid())
  userId              String
  date                DateTime @db.Date
  productiveHoursStart String? // "10:00"
  productiveHoursEnd  String?  // "13:00"
  tasksCompleted      Int      @default(0)
  totalFocusMinutes   Int      @default(0)
  avgCompletionSpeed  Float?   // minutes per task
  createdAt           DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("habit_logs")
}

// ============================================================
// Task 19 — Notification Model
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}
